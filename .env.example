# ============================================================
# APPLICATION
# ============================================================
APP_NAME="ProyectIA Backend"
APP_VERSION="0.1.0"
APP_ENV="development"          # development | staging | production
DEBUG=true
HOST=0.0.0.0
PORT=8000

# ============================================================
# CORS
# ============================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================================
# AZURE OPENAI
# ============================================================
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# ============================================================
# AZURE AI INFERENCE (Phi-3, Mistral, Llama via Azure AI Studio)
# ============================================================
AZURE_AI_INFERENCE_ENDPOINT=https://your-model.inference.ai.azure.com
AZURE_AI_INFERENCE_KEY=your_azure_ai_inference_key_here
AZURE_AI_INFERENCE_MODEL_NAME=phi-3-medium-128k-instruct  # phi-3 | mistral-large | llama-3

# ============================================================
# OPENAI DIRECT
# ============================================================
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ============================================================
# DEFAULT PROVIDER (azure_openai | azure_inference | openai)
# ============================================================
DEFAULT_AI_PROVIDER=azure_openai

# ============================================================
# LLM DEFAULTS
# ============================================================
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_STREAMING=true

# ============================================================
# DATABASE - PostgreSQL (with pgvector)
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/proyectia
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ============================================================
# VECTOR STORE
# ============================================================
VECTOR_STORE_PROVIDER=pgvector    # pgvector | faiss
VECTOR_COLLECTION_NAME=documents
EMBEDDING_DIMENSION=3072          # 1536 for ada-002 | 3072 for text-embedding-3-large

# ============================================================
# SECURITY
# ============================================================
SECRET_KEY=change-this-to-a-strong-random-secret-key-at-least-32-chars
API_KEY_HEADER=X-API-Key
API_KEYS=["dev-key-1234","prod-key-5678"]     # Comma-separated list
